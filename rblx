local MiscTab = Window:CreateTab("Misc", 15403059251)
MiscTab:CreateLabel("FastDex UI Phone - Hide the floating open button")

MiscTab:CreateButton({
    Name = "Hide Open Button",
    Callback = function()
        local function findRayfield()
            for _, obj in ipairs(CoreGui:GetChildren()) do
                if obj:FindFirstChild("Rayfield") then
                    return obj.Rayfield
                end
            end
            return nil
        end

        local RayfieldUI = findRayfield()
        if not RayfieldUI then
            warn("Rayfield UI not found.")
            return
        end

        local function fixPrompt(prompt)
            if not prompt or not prompt:FindFirstChild("Title") then return end
            prompt.Title.Visible = false
            prompt.BackgroundTransparency = 1
            prompt.Title:GetPropertyChangedSignal("Visible"):Connect(function()
                if prompt.Title.Visible then
                    prompt.Title.Visible = false
                end
            end)
            prompt:GetPropertyChangedSignal("BackgroundTransparency"):Connect(function()
                if prompt.BackgroundTransparency ~= 1 then
                    prompt.BackgroundTransparency = 1
                end
            end)
        end

        local existing = RayfieldUI:FindFirstChild("Prompt")
        if existing then
            fixPrompt(existing)
        end

        RayfieldUI.ChildAdded:Connect(function(child)
            if child.Name == "Prompt" then
                fixPrompt(child)
            end
        end)

        Rayfield:Notify({
            Title = "Hide Button",
            Content = "Open button hidden!",
            Duration = 2,
            Image = 15403175166
        })
    end
})

-- ================================
-- AutoCollect Feature (Toggleable)
-- ================================
-- The collector code (unaltered except for wrapping in a toggle)
local remote = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Networking"):WaitForChild("RE/Events/CollectEventSpawnable")
local ITEM_NAME = "Sombrero"
local IsA = game.IsA

local function collect(obj)
    if not (IsA(obj, "BasePart") or IsA(obj, "Model")) then return end
    if obj.Name == ITEM_NAME or obj:FindFirstChild(ITEM_NAME) then
        remote:FireServer(obj)
        if IsA(obj, "BasePart") then
            obj.CFrame = CFrame.new(0, 10000, 0)
        elseif IsA(obj, "Model") then
            obj:MoveTo(Vector3.new(0, 10000, 0))
        end
    end
end

local collectorConnection = nil
local collectorEnabled = false

local function startCollector()
    if collectorEnabled then return end
    collectorEnabled = true

    -- Initial scan
    task.spawn(function()
        local descendants = workspace:GetDescendants()
        for i = 1, #descendants do
            local v = descendants[i]
            if v.Name == ITEM_NAME then
                collect(v)
            end
            if i % 50 == 0 then task.wait() end
        end
    end)

    -- Listen for new items
    collectorConnection = workspace.DescendantAdded:Connect(function(newObject)
        if newObject.Name ~= ITEM_NAME and not IsA(newObject, "Model") then
            return
        end
        task.defer(collect, newObject)
    end)
end

local function stopCollector()
    if not collectorEnabled then return end
    collectorEnabled = false
    if collectorConnection then
        collectorConnection:Disconnect()
        collectorConnection = nil
    end
end

-- Add AutoCollect Tab
local AutoCollectTab = Window:CreateTab("AutoCollect", 15403175166) -- using a generic image ID
AutoCollectTab:CreateLabel("Auto-collect '" .. ITEM_NAME .. "' items (low‑lag mode)")

AutoCollectTab:CreateToggle({
    Name = "Enable AutoCollect",
    CurrentValue = false,
    Callback = function(value)
        if value then
            startCollector()
            Rayfield:Notify({
                Title = "AutoCollect",
                Content = "Collector started!",
                Duration = 2,
                Image = 15403175166
            })
        else
            stopCollector()
            Rayfield:Notify({
                Title = "AutoCollect",
                Content = "Collector stopped.",
                Duration = 2,
                Image = 15403175166
            })
        end
    end
})

