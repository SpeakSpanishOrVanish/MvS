-- ================================
-- Helper Functions (Team Detection)
-- ================================
local function getTeamFrames()
    local ok, redFrame, blueFrame = pcall(function()
        local pg = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if not pg then return nil, nil end
        local main = pg:FindFirstChild("Main")
        if not main then return nil, nil end
        local mgf = main:FindFirstChild("MainGameFrame")
        if not mgf then return nil, nil end
        local pf = mgf:FindFirstChild("PlayersFrame")
        if not pf then return nil, nil end
        return pf:FindFirstChild("TeamRedFrame"), pf:FindFirstChild("TeamBlueFrame")
    end)
    if not ok or not redFrame or not blueFrame then
        return nil, nil
    end
    return redFrame, blueFrame
end

local function readNames(frame)
    local names = {}
    for _, child in ipairs(frame:GetChildren()) do
        if child:IsA("Frame") then
            table.insert(names, child.Name)
        end
    end
    return names
end

local function normalizeName(n)
    return tostring(n):gsub("%s+", "")
end

local function getEnemies()
    local redFrame, blueFrame = getTeamFrames()
    if not redFrame or not blueFrame then
        return {}
    end

    local redRaw = readNames(redFrame)
    local blueRaw = readNames(blueFrame)

    local youInRed, youInBlue = false, false
    local redSet, blueSet = {}, {}

    for _, n in ipairs(redRaw) do
        local nn = normalizeName(n)
        redSet[nn] = true
        if nn == normalizeName(LocalPlayer.Name) then
            youInRed = true
        end
    end

    for _, n in ipairs(blueRaw) do
        local nn = normalizeName(n)
        blueSet[nn] = true
        if nn == normalizeName(LocalPlayer.Name) then
            youInBlue = true
        end
    end
    if not (youInRed or youInBlue) then
        return {}
    end

    local enemySet = youInRed and blueSet or redSet
    local enemies = {}

    for name,_ in pairs(enemySet) do
        for _, plr in ipairs(Players:GetPlayers()) do
            if normalizeName(plr.Name) == name and plr ~= LocalPlayer then
                table.insert(enemies, plr)
            end
        end
    end
    return enemies
end

-- ================================
-- Hitbox Expander (with wall check)
-- ================================
_G.HeadSize = nil
_G.Disabled = false
_G.Transparency = nil
_G.SelectedColor = nil
_G.Originals = {}
_G.AntiWall = false
local visibilityCache = {}

local function isVisible(part)
    local cam = Workspace.CurrentCamera
    if not cam then return true end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {LocalPlayer.Character}
    local result = Workspace:Raycast(cam.CFrame.Position, (part.Position - cam.CFrame.Position), params)
    if not result then return true end
    return result.Instance:IsDescendantOf(part.Parent)
end

local function applyHitbox(v)
    if v == LocalPlayer then return end
    local char = v.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if _G.AntiWall and visibilityCache[v.Name] == false then
        local orig = _G.Originals[v.Name]
        if orig then
            hrp.Size = orig.Size
            hrp.Transparency = orig.Transparency
            hrp.BrickColor = orig.Color
            hrp.Material = orig.Material
            hrp.CanCollide = true
        end
        return
    end

    if _G.Disabled then
        if not _G.Originals[v.Name] then
            _G.Originals[v.Name] = {
                Size = hrp.Size,
                Transparency = hrp.Transparency,
                Color = hrp.BrickColor,
                Material = hrp.Material
            }
        end
        if _G.HeadSize then hrp.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize) end
        if _G.Transparency then hrp.Transparency = _G.Transparency end
        if _G.SelectedColor then hrp.BrickColor = BrickColor.new(_G.SelectedColor) end
        hrp.Material = Enum.Material.Neon
        hrp.CanCollide = false
    else
        local orig = _G.Originals[v.Name]
        if orig then
            hrp.Size = orig.Size
            hrp.Transparency = orig.Transparency
            hrp.BrickColor = orig.Color
            hrp.Material = orig.Material
            hrp.CanCollide = true
        end
    end
end

local function setupPlayer(v)
    visibilityCache[v.Name] = false
    v.CharacterAdded:Connect(function()
        task.wait(0.15)
        applyHitbox(v)
    end)
    if v.Character then applyHitbox(v) end
end

for _, v in pairs(Players:GetPlayers()) do setupPlayer(v) end
Players.PlayerAdded:Connect(setupPlayer)

-- Visibility update loop for AntiWall
task.spawn(function()
    while true do
        if _G.AntiWall then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer then
                    local c = plr.Character
                    local hrp = c and c:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        visibilityCache[plr.Name] = isVisible(hrp)
                    end
                end
            end
        end
        task.wait(0.15)
    end
end)

-- Continuous hitbox application loop
task.spawn(function()
    while true do
        for _, plr in ipairs(Players:GetPlayers()) do
            applyHitbox(plr)
        end
        task.wait(0.16)
    end
end)

