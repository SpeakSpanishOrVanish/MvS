--[[
    Standalone Hitbox Expander + ESP Script + Auto Collect CincoDeMayo2026
    Extracted from MvS.lua by FrannnDev
    Features:
      - Hitbox Expander: increases enemy HumanoidRootPart size/color/transparency
      - Anti‑Wall Shot: expands hitbox only when enemy is visible
      - ESP: highlights enemies through walls (team-colored)
      - Auto Collect CincoDeMayo2026: automatically claims event reward on start/respawn
--]]

-- Load Rayfield UI library
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Services
local Players = game:GetService("Players")
