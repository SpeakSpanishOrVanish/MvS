--[[
    Safe All-in-One: Hitbox + ESP + Auto Collect Cinco
    - Distance‑filtered auto‑collect (only touches nearby pickups)
    - Slow, one‑pickup‑at‑a‑time loop to avoid crashes
--]]

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

-- ==================== Helper Functions ====================
local function normalizeName(n) return tostring(n):gsub("%s+", "") end

local function getTeamFrames()
    local ok, redFrame, blueFrame = pcall(function()
        local pg = LocalPlayer:FindFirstChildOfClass("PlayerGui")
        if not pg then return nil, nil end
        local main = pg:FindFirstChild("Main")
        if not main then return nil, nil end
        local mgf = main:FindFirstChild("MainGameFrame")
        if not mgf then return nil, nil end
        local pf = mgf:FindFirstChild("PlayersFrame")
        if not pf then return nil, nil end
        return pf:FindFirstChild("TeamRedFrame"), pf:FindFirstChild("TeamBlueFrame")
    end)
    if not ok or not redFrame or not blueFrame then return nil, nil end
    return redFrame, blueFrame
end

local function readNames(frame)
    local names = {}
    for _, child in ipairs(frame:GetChildren()) do
        if child:IsA("Frame") then table.insert(names, child.Name) end
    end
    return names
end

local function getEnemies()
    local redFrame, blueFrame = getTeamFrames()
    if not redFrame or not blueFrame then return {} end
    local redRaw = readNames(redFrame)
    local blueRaw = readNames(blueFrame)
    local youInRed, youInBlue = false, false
    local redSet, blueSet = {}, {}
    for _, n in ipairs(redRaw) do
        local nn = normalizeName(n)
        redSet[nn] = true
        if nn == normalizeName(LocalPlayer.Name) then youInRed = true end
    end
    for _, n in ipairs(blueRaw) do
        local nn = normalizeName(n)
        blueSet[nn] = true
        if nn == normalizeName(LocalPlayer.Name) then youInBlue = true end
    end
    if not (youInRed or youInBlue) then return {} end
    local enemySet = youInRed and blueSet or redSet
    local enemies = {}
    for name,_ in pairs(enemySet) do
        for _, plr in ipairs(Players:GetPlayers()) do
            if normalizeName(plr.Name) == name and plr ~= LocalPlayer then
                table.insert(enemies, plr)
            end
        end
    end
    return enemies
end

-- ==================== Hitbox Expander ====================
_G.HitboxEnabled = false
_G.AntiWall = false
_G.HeadSize = nil
_G.Transparency = nil
_G.SelectedColor = nil
_G.Originals = {}
local visibilityCache = {}

local function isVisible(part)
    local cam = Workspace.CurrentCamera
    if not cam then return true end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {LocalPlayer.Character}
    local result = Workspace:Raycast(cam.CFrame.Position, (part.Position - cam.CFrame.Position), params)
    if not result then return true end
    return result.Instance:IsDescendantOf(part.Parent)
end

local function applyHitbox(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if not _G.Originals[player.Name] then
        _G.Originals[player.Name] = {
            Size = hrp.Size,
            Transparency = hrp.Transparency,
            Color = hrp.BrickColor,
            Material = hrp.Material,
            CanCollide = hrp.CanCollide
        }
    end
    local orig = _G.Originals[player.Name]
    if _G.AntiWall and visibilityCache[player.Name] == false then
        hrp.Size = orig.Size
        hrp.Transparency = orig.Transparency
        hrp.BrickColor = orig.Color
        hrp.Material = orig.Material
        hrp.CanCollide = orig.CanCollide
        return
    end
    if _G.HitboxEnabled then
        if _G.HeadSize then hrp.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize) end
        if _G.Transparency then hrp.Transparency = _G.Transparency end
        if _G.SelectedColor then hrp.BrickColor = BrickColor.new(_G.SelectedColor) end
        hrp.Material = Enum.Material.Neon
        hrp.CanCollide = false
    else
        hrp.Size = orig.Size
        hrp.Transparency = orig.Transparency
        hrp.BrickColor = orig.Color
        hrp.Material = orig.Material
        hrp.CanCollide = orig.CanCollide
    end
end

task.spawn(function()
    while true do
        if _G.AntiWall then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer then
                    local char = plr.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if hrp then visibilityCache[plr.Name] = isVisible(hrp) end
                end
            end
        end
        task.wait(0.15)
    end
end)

task.spawn(function()
    while true do
        for _, plr in ipairs(Players:GetPlayers()) do applyHitbox(plr) end
        task.wait(0.16)
    end
end)

local function onCharacterAdded(player, character)
    character:WaitForChild("HumanoidRootPart", 5)
    task.wait(0.1)
    applyHitbox(player)
end

for _, plr in ipairs(Players:GetPlayers()) do
    plr.CharacterAdded:Connect(function(char) onCharacterAdded(plr, char) end)
    if plr.Character then onCharacterAdded(plr, plr.Character) end
end
Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function(char) onCharacterAdded(plr, char) end)
end)

-- ==================== ESP ====================
_G.ESPEnabled = false
local highlights = {}

local function removeHighlight(player)
    local h = highlights[player]
    if h then pcall(function() h:Destroy() end); highlights[player] = nil end
end

local function createHighlight(player, color)
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local h = highlights[player]
    if not h or h.Parent == nil or h.Adornee ~= char then
        if h then pcall(function() h:Destroy() end) end
        h = Instance.new("Highlight")
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.FillTransparency = 0.5
        h.OutlineColor = Color3.fromRGB(255,255,255)
        h.Parent = char
        highlights[player] = h
    end
    h.Adornee = char
    h.FillColor = color
end

local function updateESP()
    if not _G.ESPEnabled then
        for plr,_ in pairs(highlights) do removeHighlight(plr) end
        return
    end
    local enemies = getEnemies()
    if not enemies or #enemies == 0 then
        for plr,_ in pairs(highlights) do removeHighlight(plr) end
        return
    end
    local redFrame, blueFrame = getTeamFrames()
    local enemyColor = Color3.fromRGB(255,0,0)
    if redFrame and blueFrame then
        local redRaw = readNames(redFrame)
        local youInRed = false
        for _, n in ipairs(redRaw) do
            if normalizeName(n) == normalizeName(LocalPlayer.Name) then youInRed = true; break end
        end
        enemyColor = youInRed and Color3.fromRGB(0,0,255) or Color3.fromRGB(255,0,0)
    end
    local enemySet = {}
    for _, e in ipairs(enemies) do enemySet[e] = true end
    for plr,_ in pairs(highlights) do
        if not enemySet[plr] then removeHighlight(plr) end
    end
    for _, enemy in ipairs(enemies) do createHighlight(enemy, enemyColor) end
end

RunService.RenderStepped:Connect(function()
    if _G.ESPEnabled then pcall(updateESP) else for plr,_ in pairs(highlights) do removeHighlight(plr) end end
end)

for _, plr in ipairs(Players:GetPlayers()) do
    plr.CharacterAdded:Connect(function() if _G.ESPEnabled then task.defer(updateESP) end end)
end
Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function() if _G.ESPEnabled then task.defer(updateESP) end end)
end)
LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    if _G.ESPEnabled then updateESP() end
end)

-- ==================== SAFE AUTO COLLECT (Distance Filtered) ====================
_G.AutoCollectPickups = false
_G.CollectDelay = 2.0
_G.MaxCollectDistance = 150

local collectedPickups = {}
local SpawnablesClient = workspace:FindFirstChild("Spawnables") and workspace.Spawnables:FindFirstChild("SpawnablesClient")

local function getNearbyPickups()
    local pickups = {}
    if not SpawnablesClient then return pickups end
    local char = LocalPlayer.Character
    if not char then return pickups end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return pickups end
    local pos = hrp.Position
    for _, obj in ipairs(SpawnablesClient:GetChildren()) do
        if obj:IsA("BasePart") and obj:FindFirstChild("TouchInterest") and not collectedPickups[obj] then
            if (obj.Position - pos).Magnitude <= _G.MaxCollectDistance then
                table.insert(pickups, obj)
            end
        end
    end
    return pickups
end

local function touchPickup(part)
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    collectedPickups[part] = true
    pcall(function()
        firetouchinterest(hrp, part, 0)
        task.wait(0.05)
        firetouchinterest(hrp, part, 1)
    end)
    task.wait(0.1)
end

if SpawnablesClient then
    SpawnablesClient.ChildRemoved:Connect(function(obj) collectedPickups[obj] = nil end)
end

task.spawn(function()
    while true do
        if _G.AutoCollectPickups then
            local nearby = getNearbyPickups()
            if #nearby > 0 then
                touchPickup(nearby[1])
                task.wait(_G.CollectDelay)
            else
                task.wait(0.5)
            end
        else
            task.wait(0.5)
        end
    end
end)

