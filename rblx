-- ================================
-- ESP (Enemy Highlighting)
-- ================================
local espEnabled = false
local highlights = {}

local function removeHighlight(player)
    local h = highlights[player]
    if h then
        pcall(function() h:Destroy() end)
        highlights[player] = nil
    end
end

local function createHighlight(player, color)
    local char = player.Character
    if not char then return end
    if not char:FindFirstChild("HumanoidRootPart") then return end

    local h = highlights[player]
    if not h or h.Parent == nil or h.Adornee ~= char then
        if h then pcall(function() h:Destroy() end) end
        h = Instance.new("Highlight")
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.FillTransparency = 0.5
        h.OutlineColor = Color3.fromRGB(255, 255, 255)
        h.Parent = char
        highlights[player] = h
    end
    h.Adornee = char
    h.FillColor = color
end

local function updateESP()
    if not espEnabled then return end
    local enemies = getEnemies()
    if not enemies or #enemies == 0 then
        for plr, _ in pairs(highlights) do removeHighlight(plr) end
        return
    end

    -- Determine enemy team color
    local redFrame, blueFrame = getTeamFrames()
    if not redFrame or not blueFrame then return end
    local youInRed = false
    for _, n in ipairs(readNames(redFrame)) do
        if normalizeName(n) == normalizeName(LocalPlayer.Name) then
            youInRed = true
            break
        end
    end
    local enemyColor = youInRed and Color3.fromRGB(0, 0, 255) or Color3.fromRGB(255, 0, 0)

    -- Remove highlights for non-enemies
    local enemyTable = {}
    for _, e in ipairs(enemies) do enemyTable[e] = true end
    for plr, _ in pairs(highlights) do
        if not enemyTable[plr] then removeHighlight(plr) end
    end

    -- Add/update highlights for enemies
    for _, enemy in ipairs(enemies) do
        createHighlight(enemy, enemyColor)
    end
end

-- ESP Tab UI
local ESPTab = Window:CreateTab("ESP", 15403375395)
